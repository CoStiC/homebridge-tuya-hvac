{
  "name": "homebridge-tuya-hvac",
  "version": "0.1.0",
  "description": "Homebridge plugin for locally controlling Tuya-compatible HVAC devices over LAN.",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "read:state": "npm run build --silent && node scripts/read-hvac-state.mjs"
  },
  "keywords": [
    "homebridge-plugin",
    "tuya",
    "hvac",
    "heat-pump",
    "homekit"
  ],
  "author": "Pierre MARS",
  "license": "UNLICENSED",
  "type": "module",
  "private": true,
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "dependencies": {
    "tuyapi": "7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "homebridge": "2.0.0",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
