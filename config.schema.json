{
  "pluginAlias": "TuyaHvac",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": true,
  "schema": {
    "type": "object",
    "required": ["name", "deviceId", "ip", "localKey", "protocolVersion"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Nom de l’accessoire",
        "type": "string",
        "default": "Piscine",
        "minLength": 1
      },
      "deviceId": {
        "title": "Device ID Tuya",
        "type": "string",
        "minLength": 1
      },
      "ip": {
        "title": "Adresse IP",
        "type": "string",
        "minLength": 1
      },
      "localKey": {
        "title": "Local Key",
        "type": "string",
        "minLength": 1
      },
      "protocolVersion": {
        "title": "Version du protocole Tuya",
        "type": "string",
        "default": "3.5",
        "enum": ["3.5"]
      },
      "refreshIntervalSeconds": {
        "title": "Intervalle de rafraîchissement (secondes)",
        "description": "Fréquence de synchronisation de l’état réel de la PAC.",
        "type": "integer",
        "default": 30,
        "minimum": 5,
        "maximum": 3600
      }
    }
  }
}
